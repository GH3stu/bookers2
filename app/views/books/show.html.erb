<div>
  <%# 画像の表示（サイズを調整） %>
  <%= image_tag @book.get_image.variant(resize_to_limit: [100, 100]) %>
  
  <p>タイトル：<%= @book.title %></p>
  <p>説明：<%= @book.body %></p>
  
  <%# 投稿ユーザー画像（もしUserに画像がある場合はここを修正してください） %>
  <p>投稿ユーザー画像：<%= image_tag 'sample-author1.jpg' %></p>
  
  <p>ユーザーネーム：<%= @book.user.name %></p>
  <p>投稿日：<%= @book.created_at.strftime('%Y/%m/%d') %></p>
  <% if @book.user == Current.user %>
  <%= link_to "削除", book_path(@book), data: { turbo_method: :delete } %>
  <% end %>
</div>
